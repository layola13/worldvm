# Local listen address for the proxy
LISTEN_HOST=127.0.0.1
LISTEN_PORT=19091

# Upstream responses API base URL
UPSTREAM_BASE_URL=https://anyrouter.top/v1

# Upstream API key. Keep this out of source control.
UPSTREAM_API_KEY=

# Strip unsupported MCP/namespace tools before forwarding.
STRIP_MCP_TOOLS=1

# Optional: comma-separated tool types to keep. Empty means keep all except stripped ones.
# Example: function,custom,web_search
ALLOWED_TOOL_TYPES=

# Log sanitized tool stats for debugging.
LOG_TOOL_SANITIZE=1
